# ballsackOS Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string for your Linux VM
DATABASE_URL="postgresql://user:password@localhost:5432/ballsackos"

# ===========================================
# AUTHENTICATION (NextAuth.js)
# ===========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===========================================
# EMAIL (for notifications)
# ===========================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"

# ===========================================
# STORAGE (for logos, images)
# ===========================================
# AWS S3 or compatible (like DigitalOcean Spaces)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""  # Leave empty for AWS, or set for S3-compatible services

# ===========================================
# ANALYTICS
# ===========================================
# Optional: for tracking sponsor impressions externally
ANALYTICS_ID=""
